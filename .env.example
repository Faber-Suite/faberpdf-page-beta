# Server-only Formspree form ID used by app/api/feedback/route.ts.
FORMSPREE_FORM_ID="your-form-id"

# Public canonical site URL used in metadata and links.
NEXT_PUBLIC_SITE_URL="https://faberpdf.com"

# Optional public desktop download URL overrides. The app defaults to
# downloads.faberpdf.com when these are blank.
NEXT_PUBLIC_FABERPDF_WINDOWS_URL="https://downloads.faberpdf.com/windows/FaberPDF_0.1.0_x64-setup.exe"
NEXT_PUBLIC_FABERPDF_MACOS_URL="https://downloads.faberpdf.com/macos/FaberPDF.app.tar.gz"
NEXT_PUBLIC_FABERPDF_LINUX_URL="https://downloads.faberpdf.com/linux/FaberPDF_0.1.0_amd64.AppImage"
